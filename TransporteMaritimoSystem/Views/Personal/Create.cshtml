@model TransporteMaritimo.Core.Models.Personal

<h2>Registrar Personal</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label>Nombre Completo</label>
        <input asp-for="NombreCompleto" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Identificación</label>
        <input asp-for="Identificacion" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Rol Principal</label>
        <select asp-for="RolPrimario" class="form-control">
            <option>Capitan</option>
            <option>Ingeniero</option>
            <option>Marinero</option>
            <option>Personal Base</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Fecha Contratación</label>
        <input asp-for="FechaContratacion" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">
        Guardar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>

</form>